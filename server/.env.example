# pipecat-quickstart - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=
DAILY_ROOM_URL=  # Optional: leave empty to create a new room



# Cartesia (STT/TTS)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID= # Optional: defaults to "71a7ad14-091c-4e8e-a314-022ece01c121" (British Reading Lady)

# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=


# OpenAI (STT/LLM/TTS/Realtime)
OPENAI_API_KEY=
OPENAI_MODEL= # Optional: defaults to "gpt-4.1"

# Anthropic (diagram_cleanup_model / vision_model — Phase 3+)
ANTHROPIC_API_KEY=

# Google (fast_validation_model — Phase 3+)
GEMINI_API_KEY=

# Documentation mode storage root (Phase 1+)
VOICE_COCKPIT_DOCS_ROOT=  # e.g. ~/voice-cockpit-docs

